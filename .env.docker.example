###############################################################################
# .env.docker — Local Docker development environment variables
#
# USAGE
#   cp .env.docker .env.local
#   # Then start the stack:
#   docker compose up
#
# These values are intentionally hard-coded dev-only secrets.
# NEVER use these values in staging or production.
# Production secrets live in Vercel, Railway, and Supabase Cloud dashboards.
###############################################################################

# ---------------------------------------------------------------------------
# PostgreSQL (via supabase/postgres image)
# Container: db  |  Host port: 54322  |  Internal port: 5432
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres

# ---------------------------------------------------------------------------
# JWT — shared secret used by GoTrue, PostgREST, and Storage
# Must be at least 32 characters. Rotate in production via Supabase dashboard.
#
# The ANON and SERVICE_ROLE keys below are pre-signed JWTs for the local
# secret "CHANGE_ME_GENERATE_A_REAL_SECRET".
# They are standard across all Supabase local dev stacks.
# ---------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_GENERATE_A_REAL_SECRET

# anon role JWT  (role: anon)
ANON_KEY=GENERATE_JWT_WITH_YOUR_SECRET

# service_role JWT  (role: service_role, bypasses RLS — keep private)
SERVICE_ROLE_KEY=GENERATE_JWT_WITH_YOUR_SECRET

# ---------------------------------------------------------------------------
# Supabase API Gateway (Kong)
# Container: kong  |  Host port: 54321  |  This is your local SUPABASE_URL
# ---------------------------------------------------------------------------
SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=GENERATE_JWT_WITH_YOUR_SECRET
SUPABASE_SERVICE_ROLE_KEY=GENERATE_JWT_WITH_YOUR_SECRET

# ---------------------------------------------------------------------------
# Direct DB connection (bypasses Kong/PostgREST — for Drizzle, Dagster, etc.)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ---------------------------------------------------------------------------
# Redis (rate limiting + caching for the API layer)
# Container: redis  |  Host port: 6379
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# ML API (FastAPI — only active with: docker compose --profile ml up)
# Container: ml-api  |  Host port: 8000
# ---------------------------------------------------------------------------
ML_API_URL=http://localhost:8000
ML_API_SECRET=GENERATE_A_REAL_SECRET

# ---------------------------------------------------------------------------
# Dagster (pipeline orchestration — only active with: docker compose --profile ml up)
# Container: pipeline  |  Host port: 3010
# ---------------------------------------------------------------------------
DAGSTER_HOME=/opt/dagster/dagster_home

# ---------------------------------------------------------------------------
# External APIs — fill in your own keys for local development
# ---------------------------------------------------------------------------
UK_CHARITY_COMMISSION_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Maps
# ---------------------------------------------------------------------------
NEXT_PUBLIC_MAPLIBRE_STYLE_URL=https://demotiles.maplibre.org/style.json

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
FEATURE_AI_ANALYSIS=false
FEATURE_INVESTIGATION_WORKBENCH=false
FEATURE_PUBLIC_API=false
